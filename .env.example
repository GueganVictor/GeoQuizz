# Supabase credentials (Slice 6 — auth + cloud sync).
# Copy to `.env` and fill in from your project's Settings → API.
# Both are public/anon values, but kept out of git so the project URL isn't committed.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
